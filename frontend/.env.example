# MemeTools Frontend — Environment Template
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# See docs/Phase-0.3-Technology-Stack-and-Development-Standards.md, Section 5.

# Public — bundled into the client, safe to expose in the browser.
# Every variable exposed to the frontend MUST use the NEXT_PUBLIC_ prefix
# deliberately, never by accident.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
