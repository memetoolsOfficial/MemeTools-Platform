# MemeTools Backend — Environment Template
# Copy this file to .env and fill in real values. Never commit .env.
# See docs/Phase-0.3-Technology-Stack-and-Development-Standards.md, Section 5.

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database — introduced when Phase 3 (Database Integration) implements
# the Prisma schema against the entities defined in docs/Phase-0.5.
DATABASE_URL=

# Supabase (server-side only — never exposed to the frontend bundle)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
