{
  "name": "memetools",
  "version": "0.1.0",
  "private": true,
  "description": "MemeTools — Production-ready Points-Based Crypto Prediction Platform",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "build": "pnpm build:frontend && pnpm build:backend",
    "start:frontend": "pnpm --filter frontend start",
    "start:backend": "pnpm --filter backend start:prod",
    "lint": "pnpm --filter frontend lint && pnpm --filter backend lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "lint:backend": "pnpm --filter backend lint",
    "typecheck": "pnpm --filter frontend typecheck && pnpm --filter backend typecheck && pnpm --filter shared typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-unknown",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-unknown"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
